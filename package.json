{
  "name": "student_management_training",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/hana-client": "^2.27.24",
    "express": "^4",
    "@sap/xssec": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@sap/hdi-deploy": "4.9.5",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-course_ui_app": "cds watch --open com.course.app.courseuiapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-freestyle_ui5_app": "cds watch --open freestyleui5app/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy student_management_training --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      },
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true,
      "ExternalService": {
        "kind": "odata-v2",
        "model": "srv/external/ExternalService",
        "credentials": {
          "destination": "s4hana",
          "path": "/sap/opu/odata/SAP/ZSRVIC_ODATA_SRV/"
        }
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/course_ui_app"
  ]
}